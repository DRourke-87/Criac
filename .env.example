# Telegram
TELEGRAM_BOT_TOKEN=          # From @BotFather
TELEGRAM_ALLOWED_USER_ID=    # Your numeric Telegram user ID (message @userinfobot)

# Groq (free Whisper transcription — get a key at https://console.groq.com/keys)
GROQ_API_KEY=

# Claude subscription auth — run `claude setup-token` (needs Claude Pro/Max),
# paste the sk-ant-oat01-... token here. NOT an API key. Keep it secret.
CLAUDE_CODE_OAUTH_TOKEN=

# Notion (internal integration token — starts with ntn_)
NOTION_API_KEY=
NOTION_NOTES_DB_ID=          # 32-char ID from the Notes database URL
NOTION_TASKS_DB_ID=          # 32-char ID from the Tasks database URL
NOTION_DRAFTS_DB_ID=         # 32-char ID from the Drafts database URL

# Google Calendar (optional — leave blank to disable calendar tools)
# Calendar ID: Google Calendar → Settings → your shared calendar → "Calendar ID"
# For a shared family calendar it looks like: abc123@group.calendar.google.com
# Omit or set to "primary" to use your own main Google calendar.
GOOGLE_CALENDAR_ID=
TIMEZONE=Europe/London       # IANA timezone name for event creation

# Persistent memory (optional — create a "Memory" database in Notion, share it
# with your integration, and paste the 32-char database ID here).
# Database needs these properties: Key (title), Value (rich text),
# Category (select: Clients/Projects/Preferences/Decisions/Context/Other),
# Tags (multi-select), Active (checkbox, default true).
NOTION_MEMORY_DB_ID=

# Brave Search API (optional — get a free key at https://brave.com/search/api/)
# Enables real-time web search via the web_search tool.
BRAVE_API_KEY=

# Alexa Skill (optional — paste your Skill ID to validate incoming requests).
# Find it in the Alexa Developer Console under your skill's Skill ID.
# Format: amzn1.ask.skill.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ALEXA_SKILL_ID=

# Gmail (optional — leave blank to disable). Comma-separated list of sender
# addresses to monitor; the bot only ever queries Gmail for mail from these
# addresses and pushes a Telegram message when new mail from them arrives.
GMAIL_ALLOWED_SENDERS=
GMAIL_POLL_INTERVAL_SECONDS=300
